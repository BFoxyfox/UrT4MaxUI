		// This controls both the dark glow
		// on the unselected race and the
		// bold border on mouse over
		itemDef {
			name ally_female0_br
			rect 16 110 100 100
			style 1
			backcolor 0.12 0.2 0.3 0.9
			type 0
			visible 1
			border 1
			bordersize 2
			bordercolor 0 0 .55 0
			mouseEnter { setitemcolor ally_female0_br bordercolor .55 0 0 1 }
			mouseExit { setitemcolor ally_female0_br bordercolor .55 0 0 0 }
			decoration
		}

