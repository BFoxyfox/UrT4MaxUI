#include "ui/menudef.h"
#include "ui/theme.inc"
{

	// PLAYER MENU

	////////////////////////////
	// STANDARD MENU CREATION //
	////////////////////////////

	menuDef {

		name "psetup_menu"
		visible 0
		fullscreen 0
		rect 75 20 490 440
		focusColor 1 1 1 1
		style 1
		border 0
		popup
		onEsc  { close psetup_menu ; open setup_menu ; uiScript update "ui_SetName" }
		onOpen { uiScript update "ui_GetName" ; setfocus window }
		onClose { uiScript update "ui_SetName" }


		itemDef {
			name window
			group grpPsetupbutton
			rect 10 10 460 420
			style 1
			border 0
			forecolor 1 1 1 1
			backcolor 0.05 0.07 0.1 0.9
			visible 1
			decoration
			
			
		}

			itemDef {
				name psetup_close_btn
				type 1
				style WINDOW_STYLE_FILLED
				rect 396 14 74 22
				forecolor 1 1 1 1
				backcolor 0.12 0.2 0.3 0.9
				border 0
				visible 1
				action { play "sound/misc/kcaction.wav" ; close psetup_menu ; open setup_menu }
				mouseEnter { setitemcolor psetup_close_btn backcolor 0.16 0.26 0.38 0.95 }
				mouseExit { setitemcolor psetup_close_btn backcolor 0.12 0.2 0.3 0.9 }
			}

		
		itemDef { name psetup_close_icon style WINDOW_STYLE_SHADER background "ui/assets/urt4_icon_close.tga" rect 402 17 14 14 visible 1 decoration }
itemDef {
			name psetup_close_text
			text "Close"
			type 0
			textscale .26
			style WINDOW_STYLE_FILLED
			rect 396 14 74 22
			textalign 1
			textalignx 44
			textaligny 17
			forecolor 1 1 1 1
			backcolor 0 0 0 0
			border 0
			visible 1
			decoration
		}

		itemDef {
			group grpPsetupbutton
			name psetupangle
			style WINDOW_STYLE_SHADER
			visible 0
			background "ui/assets/angle.tga"
			rect 450 12 16 16
			visible 0
			decoration
		}

		itemDef {
			group grpPsetupbutton
			name psetupangle_on
			style WINDOW_STYLE_SHADER
			visible 0
			background "ui/assets/angle_on.tga"
			rect 450 12 16 16
			visible 0
			decoration
		}

		itemDef {
			name areaname
			group grpControlbutton
			text "Pick ally/enemy skins and armband palette"
			textscale .22
			textalignx 0
			textaligny 20
			rect 20 364 430 28
			style 1
			forecolor 0.82 0.88 0.96 0.45
			visible 1
			decoration
		}


		//////////////////
		
		//////////////////
		// INSTRUCTIONS // //
		//////////////////

			itemdef {
				name instruction_button
				rect 336 40 56 18
				type 1
				style WINDOW_STYLE_FILLED
				forecolor 1 1 1 1
				backcolor 0.12 0.2 0.3 0.9
				border 0
				visible 1
				action { setcolor backcolor 0.12 0.2 0.3 0.9; play "sound/misc/kcaction.wav"; close psetup_menu ; open psetup_menu_readme }
				mouseEnter { setcolor backcolor 0.12 0.2 0.3 0.955}
				mouseExit { setcolor backcolor 0.12 0.2 0.3 0.9 }
			}

		itemdef {
			name instruction_button2
			rect 336 40 56 18
			type 0
			text "README"
			textscale .20
			textalign 1
			textalignx 28
			textaligny 15
				style WINDOW_STYLE_FILLED
				forecolor 1 1 1 1
				backcolor 0 0 0 0
				border 0
				visible 1
				decoration
			}

						itemDef {
							name fixed_mod
							rect 394 40 58 18
						group "playersettinggroup"
						type ITEM_TYPE_MULTI
					text ""
					cvar "cg_skinFixed"
							cvarStrList { "^7RELATIVE", "0", "^7FIXED", "1" }
							textalign 0
							textalignx 4
							textaligny 14
							textscale .14
				style WINDOW_STYLE_FILLED
				forecolor 1 1 1 1
				backcolor 0.10 0.26 0.20 0.92
				visible 1
				border 0
				action { play "sound/misc/kcaction.wav" }
				mouseEnter { setitemcolor fixed_mod backcolor 0.12 0.31 0.24 0.96 }
				mouseExit { setitemcolor fixed_mod backcolor 0.10 0.26 0.20 0.92 }
			}

		////////////////
		// PLAYERMENU //
		////////////////

		itemDef {
			name namefield
			rect 10 20 220 20
			group "playersettinggroup"
			type ITEM_TYPE_EDITFIELD
			text "Nickname:"
			cvar "ui_Name"
			maxchars 26
			textalign 0
			textalignx 20
			textaligny 12
			textscale .25
			style WINDOW_STYLE_FILLED
			forecolor 1 1 1 1
			visible 1
		}

		itemDef {
			name rgbchooser
			rect 10 44 220 20
			group "playersettinggroup"
			type ITEM_TYPE_MULTI
			text "Armband color:"
			cvar "cg_rgb"
			cvarStrList { "^7White", "255 255 255", "^7Grey", "128 128 128", "^7Black", "0 0 0", "^1Red", "255 0 0", "^2Green", "0 255 0", "^4Blue", "0 0 255", "^3Yellow", "255 255 0", "^5Cyan", "0 255 255", "^6Magenta", "255 0 255" }
			textalign 0
			textalignx 19
			textaligny 10
			textscale .25
			visible 1
			action { play "sound/misc/kcaction.wav" }
		}
		itemDef {
			name rgb_palette_bg
			rect 10 66 220 16
			style WINDOW_STYLE_FILLED
			backcolor 0.05 0.07 0.10 0.60
			visible 1
			decoration
		}
		itemDef { name rgb_white type ITEM_TYPE_BUTTON style WINDOW_STYLE_FILLED rect 20 68 12 12 backcolor 1 1 1 1 visible 1 action { exec "seta cg_rgb 255 255 255" ; play "sound/misc/kcaction.wav" } }
		itemDef { name rgb_grey type ITEM_TYPE_BUTTON style WINDOW_STYLE_FILLED rect 42 68 12 12 backcolor 0.5 0.5 0.5 1 visible 1 action { exec "seta cg_rgb 128 128 128" ; play "sound/misc/kcaction.wav" } }
		itemDef { name rgb_black type ITEM_TYPE_BUTTON style WINDOW_STYLE_FILLED rect 64 68 12 12 backcolor 0 0 0 1 visible 1 action { exec "seta cg_rgb 0 0 0" ; play "sound/misc/kcaction.wav" } }
		itemDef { name rgb_red type ITEM_TYPE_BUTTON style WINDOW_STYLE_FILLED rect 86 68 12 12 backcolor 1 0 0 1 visible 1 action { exec "seta cg_rgb 255 0 0" ; play "sound/misc/kcaction.wav" } }
		itemDef { name rgb_green type ITEM_TYPE_BUTTON style WINDOW_STYLE_FILLED rect 108 68 12 12 backcolor 0 1 0 1 visible 1 action { exec "seta cg_rgb 0 255 0" ; play "sound/misc/kcaction.wav" } }
		itemDef { name rgb_blue type ITEM_TYPE_BUTTON style WINDOW_STYLE_FILLED rect 130 68 12 12 backcolor 0 0 1 1 visible 1 action { exec "seta cg_rgb 0 0 255" ; play "sound/misc/kcaction.wav" } }
		itemDef { name rgb_yellow type ITEM_TYPE_BUTTON style WINDOW_STYLE_FILLED rect 152 68 12 12 backcolor 1 1 0 1 visible 1 action { exec "seta cg_rgb 255 255 0" ; play "sound/misc/kcaction.wav" } }
		itemDef { name rgb_cyan type ITEM_TYPE_BUTTON style WINDOW_STYLE_FILLED rect 174 68 12 12 backcolor 0 1 1 1 visible 1 action { exec "seta cg_rgb 0 255 255" ; play "sound/misc/kcaction.wav" } }
		itemDef { name rgb_magenta type ITEM_TYPE_BUTTON style WINDOW_STYLE_FILLED rect 196 68 12 12 backcolor 1 0 1 1 visible 1 action { exec "seta cg_rgb 255 0 255" ; play "sound/misc/kcaction.wav" } }

		itemDef { name psetup_ally_panel style WINDOW_STYLE_FILLED rect 14 108 430 108 backcolor 0.05 0.07 0.10 0.36 visible 1 decoration }
		itemDef { name psetup_enemy_panel style WINDOW_STYLE_FILLED rect 14 244 430 108 backcolor 0.05 0.07 0.10 0.36 visible 1 decoration }

		///////////////////////
		// ALLY TEAM CHOSING //
		///////////////////////

		itemDef {
			name instruction
			rect 0 86 320 20
			type ITEM_TYPE_MULTI
			text "Choose the skin for the ally team:"
			cvar "cg_skinAlly"
			cvarStrList { "^3DEFAULT", "0", "^3GRIFFINS", "1", "^3RED DRAGONS", "2", "^3SWAT", "3", "^3PURPLE HAZE", "4", "^3FUGITIVES", "5", "^3OILERS", "6", "^3ICE DRAGONS", "7", "^3BLACK ICE", "8", "^3DESERT", "9", "^3COWBOY", "10", "^3CAVALRY", "11", "^3DROOGS", "12", "^3DrPINK", "13", "DrBLUE", "14" }
			textalign 0
			textalignx 20
			textaligny 20
			textscale 0.25
			visible 1
			action { play "sound/misc/kcaction.wav" }
		}

